# =============================================================================
# Nyaya-Legal-AI — .gitignore
# =============================================================================

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
*.dll

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.conda/
*.virtualenv
# Local project venv
backend/.nyaya/

# ── Model Weights & Checkpoints (too large for GitHub) ───────────────────────
# Model weights — upload to HuggingFace Hub instead
backend/kaggle/nyaya7b-finetuning-output/
backend/kaggle/.git/
backend/kaggle/wandb/
checkpoints/
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.onnx
*.model

# ── Large Data Files ──────────────────────────────────────────────────────────
# Raw & labelled data — too large, not useful to end-users
backend/data/raw/
backend/data/processed/train.jsonl
backend/data/processed/labelled.jsonl
labelled.jsonl

# ── Vector / ChromaDB Stores ──────────────────────────────────────────────────
backend/data/chroma_precedents/
backend/data/chroma_statutes/
backend/data/statute_corpus/

# ── Keep these data files (small, needed to reproduce benchmark) ─────────────
# backend/data/test_set/test.jsonl         ← INCLUDED (5MB, needed for eval)
# backend/data/processed/dataset_stats.json ← INCLUDED (tiny stats file)

# ── Benchmark Results (keep the final ones, skip intermediate) ────────────────
# Keep final JSON/CSV benchmark results and the chart
backend/evaluation/results/checkpoint_*.jsonl
# But keep:
# benchmark_*.json   ← INCLUDED
# benchmark_*.csv    ← INCLUDED
# benchmark_*.png    ← INCLUDED

# ── Jupyter Notebooks (outputs only) ─────────────────────────────────────────
# Keep .ipynb files but strip outputs
*.ipynb_checkpoints/
.ipynb_checkpoints/

# ── Wandb Logs ────────────────────────────────────────────────────────────────
wandb/
*.wandb

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep Dockerfile and docker-compose.yml — exclude runtime artifacts
*.tar
docker_volumes/

# ── ChromaDB / SQLite ─────────────────────────────────────────────────────────
*.chroma
*.sqlite3
*.db

# ── Pytest / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── MyPy ─────────────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json

# ── Ruff / Linting ────────────────────────────────────────────────────────────
.ruff_cache/

# ── Temporary / Scratch ───────────────────────────────────────────────────────
tmp/
temp/
scratch/
*.tmp
*.bak

# ── HuggingFace Cache ─────────────────────────────────────────────────────────
.cache/
~/.cache/huggingface/
